# Copiar como .env.local y completar (nunca commitear el .env.local real).

# URL del backend. En local: http://localhost:4000
# En producción (Vercel): la URL pública del servicio de Railway, ej.
# https://legion-roller-backend-production.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:4000

# Debe ser igual a VAPID_PUBLIC_KEY del backend (es pública, no es secreta).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
